50 3 * * * root mkdir -p /home/backups/cedartoy && tar -zcf /home/backups/cedartoy/data_$(date +\%Y\%m\%d).tar.gz -C /opt/cedartoy data && find /home/backups/cedartoy -name "data_*.tar.gz" -mtime +7 -delete
